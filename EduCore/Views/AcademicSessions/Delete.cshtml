@model EduCore.Models.AcademicSession

@{
    ViewData["Title"] = "Delete Academic Session";
}

<h2 class="mb-4">Delete Academic Session</h2>

<div class="alert alert-danger">
    <h5 class="mb-0">
        <i class="bi bi-exclamation-triangle-fill"></i>
        Are you sure you want to delete this Academic Session?
    </h5>
    <small>
        This action cannot be undone.
    </small>
</div>

<div class="card shadow-sm">

    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">Academic Session Information</h5>
    </div>

    <div class="card-body">

        <table class="table table-borderless">

            <tr>
                <th width="220">Session Name</th>
                <td>@Model.SessionName</td>
            </tr>

            <tr>
                <th>Academic Program</th>
                <td>@Model.AcademicProgram?.ProgramName</td>
            </tr>

            <tr>
                <th>Duration</th>
                <td>@Model.StartYear - @Model.EndYear</td>
            </tr>

            <tr>
                <th>Admissions</th>
                <td>
                    @if (Model.IsAdmissionOpen)
                    {
                        <span class="badge bg-success">Open</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Closed</span>
                    }
                </td>
            </tr>

            <tr>
                <th>Status</th>
                <td>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </td>
            </tr>

            <tr>
                <th>Created On</th>
                <td>@Model.CreatedDate.ToString("dd MMM yyyy")</td>
            </tr>

        </table>

    </div>

</div>

<div class="mt-4">

    <form asp-action="Delete">

        <input type="hidden" asp-for="AcademicSessionId" />

        <button type="submit" class="btn btn-danger">
            Delete Academic Session
        </button>

        <a asp-action="Details"
           asp-route-id="@Model.AcademicSessionId"
           class="btn btn-info text-white">
            Back to Details
        </a>

        <a asp-action="Index"
           class="btn btn-secondary">
            Back to List
        </a>

    </form>

</div>