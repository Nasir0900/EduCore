@model IEnumerable<EduCore.Models.EmployeeLeave>

@{
    ViewData["Title"] = "Employee Leaves";
}

<h2 class="mb-4">Employee Leave Applications</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">

        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

<div class="mb-3">

    <a asp-action="Create"
       class="btn btn-primary">

        Apply Leave

    </a>

</div>

<table class="table table-bordered table-hover align-middle">

    <thead class="table-dark">

        <tr>

            <th>Leave No.</th>

            <th>Employee</th>

            <th>Leave Type</th>

            <th>From</th>

            <th>To</th>

            <th>Total Days</th>

            <th>Status</th>

            <th>Applied</th>

            <th width="220">Actions</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>

                    <span class="badge bg-secondary">

                        @item.LeaveNumber

                    </span>

                </td>

                <td>

                    @item.Employee?.FullName

                </td>

                <td>

                    @item.LeaveType?.LeaveTypeName

                </td>

                <td>

                    @item.FromDate.ToShortDateString()

                </td>

                <td>

                    @item.ToDate.ToShortDateString()

                </td>

                <td>

                    @item.TotalDays

                </td>

                <td>

                    @switch (item.Status)
                    {
                        case EduCore.Enums.LeaveStatus.Pending:
                            <span class="badge bg-warning text-dark">Pending</span>
                            break;

                        case EduCore.Enums.LeaveStatus.Approved:
                            <span class="badge bg-success">Approved</span>
                            break;

                        case EduCore.Enums.LeaveStatus.Rejected:
                            <span class="badge bg-danger">Rejected</span>
                            break;

                        case EduCore.Enums.LeaveStatus.Cancelled:
                            <span class="badge bg-secondary">Cancelled</span>
                            break;
                    }

                </td>

                <td>

                    @item.AppliedDate.ToShortDateString()

                </td>

                <td>

                    <a asp-action="Details"
                       asp-route-employeeleaveid="@item.EmployeeLeaveId"
                       class="btn btn-info btn-sm text-white">

                        Details

                    </a>

                    <a asp-action="Edit"
                       asp-route-employeeleaveid="@item.EmployeeLeaveId"
                       class="btn btn-warning btn-sm">

                        Edit

                    </a>

                    <a asp-action="Delete"
                       asp-route-employeeleaveid="@item.EmployeeLeaveId"
                       class="btn btn-danger btn-sm">

                        Delete

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>