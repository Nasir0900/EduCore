@model EduCore.Models.EmployeeLeave

@{
    ViewData["Title"] = "Apply Leave";
}

<h2 class="mb-4">Apply Leave</h2>

<form asp-action="Create" enctype="multipart/form-data">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white">

            Leave Application

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-4">

                    <label asp-for="LeaveNumber" class="form-label"></label>

                    <input asp-for="LeaveNumber"
                           class="form-control"
                           readonly />

                </div>

                <div class="col-md-4">

                    <label asp-for="EmployeeId" class="form-label"></label>

                    <select asp-for="EmployeeId"
                            class="form-select"
                            asp-items="ViewBag.EmployeeId">

                        <option value="">-- Select Employee --</option>

                    </select>

                    <span asp-validation-for="EmployeeId"
                          class="text-danger"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="LeaveTypeId" class="form-label"></label>

                    <select asp-for="LeaveTypeId"
                            id="LeaveTypeId"
                            class="form-select"
                            asp-items="ViewBag.LeaveTypeId">

                        <option value="">-- Select Leave Type --</option>

                    </select>

                    <span asp-validation-for="LeaveTypeId"
                          class="text-danger"></span>

                </div>

            </div>

            <hr />

            <div class="row">

                <div class="col-md-3">

                    <label asp-for="FromDate" class="form-label"></label>

                    <input asp-for="FromDate"
                           type="date"
                           class="form-control"
                           id="FromDate" />

                </div>

                <div class="col-md-3">

                    <label asp-for="ToDate" class="form-label"></label>

                    <input asp-for="ToDate"
                           type="date"
                           class="form-control"
                           id="ToDate" />

                </div>

                <div class="col-md-3">

                    <label asp-for="TotalDays" class="form-label"></label>

                    <input asp-for="TotalDays"
                           class="form-control"
                           id="TotalDays"
                           readonly />

                </div>

                <div class="col-md-3">

                    <div class="form-check mt-4">

                        <input asp-for="IsHalfDay"
                               class="form-check-input"
                               id="IsHalfDay" />

                        <label asp-for="IsHalfDay"
                               class="form-check-label"></label>

                    </div>

                </div>

            </div>

            <hr />

            <div class="mb-3">

                <label asp-for="Reason" class="form-label"></label>

                <textarea asp-for="Reason"
                          rows="4"
                          class="form-control"></textarea>

                <span asp-validation-for="Reason"
                      class="text-danger"></span>

            </div>

            <div class="mb-3" id="AttachmentSection" style="display:none;">

                <label class="form-label">

                    Supporting Document

                </label>

                <input type="file"
                       name="AttachmentFile"
                       class="form-control" />
                <span class="text-danger">
                    @Html.ValidationMessage("AttachmentFile")
                </span>

            </div>

        </div>

        <div class="card-footer">

            <button type="submit"
                    class="btn btn-success">

                Apply Leave

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Cancel

            </a>

        </div>

    </div>

</form>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        function calculateDays() {

            let fromDate =
                document.getElementById("FromDate").value;

            let toDate =
                document.getElementById("ToDate").value;

            let halfDay =
                document.getElementById("IsHalfDay").checked;

            let totalDays =
                document.getElementById("TotalDays");

            if (fromDate === "" || toDate === "")
            {
                totalDays.value = "";
                return;
            }

            let start = new Date(fromDate);
            let end = new Date(toDate);

            let difference =
                (end - start) / (1000 * 60 * 60 * 24);

            if (difference < 0)
            {
                totalDays.value = "";
                return;
            }

            let days = difference + 1;

            if (halfDay)
                days = 0.5;

            totalDays.value = days;

        }

        document.getElementById("FromDate")
            .addEventListener("change", calculateDays);

        document.getElementById("ToDate")
            .addEventListener("change", calculateDays);

        document.getElementById("IsHalfDay")
            .addEventListener("change", calculateDays);

                async function checkLeaveType() {

            let leaveTypeId =
                document.getElementById("LeaveTypeId").value;

            let attachment =
                document.getElementById("AttachmentSection");

            if (leaveTypeId === "") {

                attachment.style.display = "none";
                return;

            }

            const response =
                await fetch(`/EmployeeLeaves/GetLeaveType?leaveTypeId=${leaveTypeId}`);

            const data =
                await response.json();

            if (data.success) {

                attachment.style.display =
                    data.requiresDocuments ? "block" : "none";

            }

        }
                document.getElementById("LeaveTypeId")
            .addEventListener("change", checkLeaveType);

        window.onload = function () {

            calculateDays();

            checkLeaveType();

        };

    </script>

}