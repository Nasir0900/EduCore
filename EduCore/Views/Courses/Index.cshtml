@model IEnumerable<EduCore.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h2>Courses</h2>

<p class="text-muted">
    Total Courses:
    <strong>@Model.Count()</strong>
</p>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Create New Course
    </a>
</p>

@if (Model.Any())
{
    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>

                <th>Code</th>

                <th>Course Title</th>

                <th>Department</th>

                <th>Semester</th>

                <th>Type</th>

                <th>Category</th>

                <th>Credits</th>

                <th>Status</th>

                <th width="210">
                    Actions
                </th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        <span class="badge bg-dark">
                            @item.CourseCode
                        </span>
                    </td>

                    <td>
                        @item.CourseTitle
                    </td>

                    <td>
                        @item.Department?.DepartmentName
                    </td>

                    <td>
                        @item.Semester?.SemesterName
                    </td>

                    <td>
                        @item.CourseType
                    </td>

                    <td>
                        @item.CourseCategory
                    </td>

                    <td>
                        @item.CreditHours
                    </td>

                    <td>

                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Inactive
                            </span>
                        }

                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.CourseId"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.CourseId"
                           class="btn btn-sm btn-info text-white">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.CourseId"
                           class="btn btn-sm btn-danger">
                            Delete
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>
}
else
{
    <div class="alert alert-info">

        No courses have been created yet.

    </div>
}