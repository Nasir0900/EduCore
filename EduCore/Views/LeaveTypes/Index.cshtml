@model IEnumerable<EduCore.Models.LeaveType>

@{
    ViewData["Title"] = "Leave Types";
}

<h2>Leave Types</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">

        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

<div class="mb-3">

    <a asp-action="Create"
       class="btn btn-primary">

        Create Leave Type

    </a>

</div>

<table class="table table-bordered table-hover">

    <thead class="table-dark">

        <tr>

            <th>Code</th>

            <th>Leave Type</th>

            <th>Maximum Days</th>

            <th>Paid</th>

            <th>Approval</th>

            <th>Documents</th>

            <th>Carry Forward</th>

            <th>Status</th>

            <th width="210">Actions</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>

                    <span class="badge bg-secondary">

                        @item.LeaveCode

                    </span>

                </td>

                <td>

                    @item.LeaveTypeName

                </td>

                <td>

                    @item.MaximumDays

                </td>

                <td>

                    @if (item.IsPaidLeave)
                    {
                        <span class="badge bg-success">
                            Paid
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Unpaid
                        </span>
                    }

                </td>

                <td>

                    @if (item.RequiresApproval)
                    {
                        <span class="badge bg-success">
                            Required
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            No
                        </span>
                    }

                </td>

                <td>

                    @if (item.RequiresDocuments)
                    {
                        <span class="badge bg-warning text-dark">
                            Required
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            No
                        </span>
                    }

                </td>

                <td>

                    @if (item.AllowCarryForward)
                    {
                        <span class="badge bg-info">
                            Yes
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            No
                        </span>
                    }

                </td>

                <td>

                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">
                            Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Inactive
                        </span>
                    }

                </td>

                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.LeaveTypeId"
                       class="btn btn-warning btn-sm">

                        Edit

                    </a>

                    <a asp-action="Details"
                       asp-route-id="@item.LeaveTypeId"
                       class="btn btn-info btn-sm text-white">

                        Details

                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.LeaveTypeId"
                       class="btn btn-danger btn-sm">

                        Delete

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>