@model EduCore.Models.AcademicSession

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this Academic Session?</h3>

<div>

    <h4>Academic Session</h4>

    <hr />

    <dl class="row">

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.SessionName)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.SessionName)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.StartYear)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.StartYear)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.EndYear)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.EndYear)
        </dd>

        <dt class="col-sm-3">
            Academic Program
        </dt>
        <dd class="col-sm-9">
            @Model.AcademicProgram?.ProgramName
        </dd>

        <dt class="col-sm-3">
            Admissions
        </dt>
        <dd class="col-sm-9">
            @(Model.IsAdmissionOpen ? "Open" : "Closed")
        </dd>

        <dt class="col-sm-3">
            Status
        </dt>
        <dd class="col-sm-9">
            @(Model.IsActive ? "Active" : "Inactive")
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.CreatedDate)
        </dd>

    </dl>

    <form asp-action="Delete">

        <input type="hidden" asp-for="AcademicSessionId" />

        <input type="submit"
               value="Delete"
               class="btn btn-danger" />

        <a asp-action="Index"
           class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>