@model IEnumerable<EduCore.Models.AcademicSession>

@{
    ViewData["Title"] = "Academic Sessions";
}

<h2 class="mb-4">Academic Sessions</h2>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i>
        Create Academic Session
    </a>
</div>

<div class="card shadow-sm">

    <div class="card-body p-0">

        <table class="table table-striped table-hover align-middle mb-0">

            <thead class="table-dark">

                <tr>
                    <th>Session</th>
                    <th>Program</th>
                    <th>Duration</th>
                    <th>Admissions</th>
                    <th>Status</th>
                    <th>Structure</th>
                    <th>Created</th>
                    <th width="220">Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <strong>@item.SessionName</strong>
                        </td>

                        <td>
                            @item.AcademicProgram?.ProgramName
                        </td>

                        <td>
                            @item.StartYear - @item.EndYear
                        </td>

                        <td>
                            @if (item.IsAdmissionOpen)
                            {
                                <span class="badge bg-success">
                                    Open
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Closed
                                </span>
                            }
                        </td>

                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-primary">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Inactive
                                </span>
                            }
                        </td>

                        <td>

                            @if (item.Parts != null && item.Parts.Any())
                            {
                                <span class="badge bg-success">
                                    Generated
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            }

                        </td>

                        <td>
                            @item.CreatedDate.ToString("dd MMM yyyy")
                        </td>

                        <td>

                            <div class="btn-group" role="group">

                                <a asp-action="Details"
                                   asp-route-id="@item.AcademicSessionId"
                                   class="btn btn-sm btn-info text-white">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.AcademicSessionId"
                                   class="btn btn-sm btn-warning">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.AcademicSessionId"
                                   class="btn btn-sm btn-danger">
                                    Delete
                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>