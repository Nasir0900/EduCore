@model EduCore.Models.Department

@{
    ViewData["Title"] = "Delete Department";
}

<h2>Delete Department</h2>

<div class="alert alert-danger">
    <strong>Warning!</strong> Are you sure you want to delete this department?
</div>

<div class="card shadow-sm">

    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">Department Information</h5>
    </div>

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.DepartmentName)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.DepartmentName)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.DepartmentCode)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.DepartmentCode)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Description)
            </dd>

            <dt class="col-sm-3">
                Faculty
            </dt>
            <dd class="col-sm-9">
                @Model.Faculty?.FacultyName
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.CreatedDate)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.CreatedDate)
            </dd>

        </dl>

    </div>

</div>

<div class="mt-3">

    <form asp-action="Delete">

        <input type="hidden" asp-for="DepartmentId" />

        <button type="submit" class="btn btn-danger">
            Delete Department
        </button>

        <a asp-action="Details"
           asp-route-id="@Model.DepartmentId"
           class="btn btn-info text-white">
            Back to Details
        </a>

        <a asp-action="Index"
           class="btn btn-secondary">
            Back to List
        </a>

    </form>

</div>