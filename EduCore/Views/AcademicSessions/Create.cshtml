@model EduCore.Models.AcademicSession

@{
    ViewData["Title"] = "Create Academic Session";
}

<h2>Create Academic Session</h2>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="AcademicProgramId" class="form-label"></label>

                <select asp-for="AcademicProgramId"
                        class="form-select"
                        asp-items="ViewBag.AcademicProgramId">
                    <option value="">-- Select Academic Program --</option>
                </select>

                <span asp-validation-for="AcademicProgramId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartYear" class="form-label"></label>

                <select asp-for="StartYear" class="form-select">

                    <option value="">-- Select Start Year --</option>

                    @{
                        int currentYear = DateTime.Now.Year;

                        for (int year = currentYear; year <= currentYear + 10; year++)
                        {
                            <option value="@year">@year</option>
                        }
                    }

                </select>

                <span asp-validation-for="StartYear" class="text-danger"></span>
            </div>

            <div class="form-check mb-2">
                <input asp-for="IsAdmissionOpen" class="form-check-input" />
                <label asp-for="IsAdmissionOpen" class="form-check-label"></label>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">
                Create Academic Session
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}