@model EduCore.ViewModels.ModuleCardViewModel

<a asp-controller="@Model.Controller"
   asp-action="Index"
   class="module-card">

    <div class="module-icon">

        <i class="bi @Model.Icon"></i>

    </div>

    <div class="module-title">

        @Model.Title

    </div>

    <div class="module-description">

        @Model.Description

    </div>

    <div class="module-footer">

        Open Module →

    </div>

</a>