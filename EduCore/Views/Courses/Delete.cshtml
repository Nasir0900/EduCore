@model EduCore.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<h2>Delete Course</h2>

<div class="alert alert-danger">
    <strong>Warning!</strong> Are you sure you want to delete this course?
</div>

<hr />

<dl class="row">

    <dt class="col-sm-3">
        Course Code
    </dt>

    <dd class="col-sm-9">
        @Model.CourseCode
    </dd>

    <dt class="col-sm-3">
        Course Title
    </dt>

    <dd class="col-sm-9">
        @Model.CourseTitle
    </dd>

    <dt class="col-sm-3">
        Department
    </dt>

    <dd class="col-sm-9">
        @Model.Department?.DepartmentName
    </dd>

    <dt class="col-sm-3">
        Semester
    </dt>

    <dd class="col-sm-9">
        @Model.Semester?.SemesterName
    </dd>

    <dt class="col-sm-3">
        Course Type
    </dt>

    <dd class="col-sm-9">
        @Model.CourseType
    </dd>

    <dt class="col-sm-3">
        Course Category
    </dt>

    <dd class="col-sm-9">
        @Model.CourseCategory
    </dd>

    <dt class="col-sm-3">
        Credit Hours
    </dt>

    <dd class="col-sm-9">
        @Model.CreditHours
    </dd>

    <dt class="col-sm-3">
        Status
    </dt>

    <dd class="col-sm-9">

        @if (Model.IsActive)
        {
            <span class="badge bg-success">
                Active
            </span>
        }
        else
        {
            <span class="badge bg-danger">
                Inactive
            </span>
        }

    </dd>

</dl>

<form asp-action="Delete">

    <input type="hidden"
           asp-for="CourseId" />

    <button type="submit"
            class="btn btn-danger">
        Delete Course
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>