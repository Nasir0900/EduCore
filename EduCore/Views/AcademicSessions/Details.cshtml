@model EduCore.Models.AcademicSession

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>

    <h4>Academic Session</h4>

    <hr />

    <dl class="row">

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.SessionName)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.SessionName)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.StartYear)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.StartYear)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.EndYear)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.EndYear)
        </dd>

        <dt class="col-sm-3">
            Academic Program
        </dt>
        <dd class="col-sm-9">
            @Model.AcademicProgram?.ProgramName
        </dd>

        <dt class="col-sm-3">
            Admissions
        </dt>
        <dd class="col-sm-9">
            @(Model.IsAdmissionOpen ? "Open" : "Closed")
        </dd>

        <dt class="col-sm-3">
            Status
        </dt>
        <dd class="col-sm-9">
            @(Model.IsActive ? "Active" : "Inactive")
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.CreatedDate)
        </dd>

    </dl>

</div>

<div>
    <a asp-action="Edit"
       asp-route-id="@Model?.AcademicSessionId"
       class="btn btn-primary">
        Edit
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back to List
    </a>
</div>