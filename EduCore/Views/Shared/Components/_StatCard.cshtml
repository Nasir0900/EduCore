@model EduCore.ViewModels.StatCardViewModel

<div class="stat-card">

    <div class="stat-icon bg-@Model.Color">

        <i class="bi @Model.Icon"></i>

    </div>

    <div class="stat-content">

        <div class="stat-value">

            @Model.Value

        </div>

        <div class="stat-title">

            @Model.Title

        </div>

    </div>

</div>