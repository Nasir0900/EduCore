@model IEnumerable<EduCore.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<h2>Employee Management</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">

        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

<div class="card mb-4">

    <div class="card-header bg-primary text-white">

        <h5 class="mb-0">

            Search & Filters

        </h5>

    </div>
    
    <div class="card-body">

        <form asp-action="Index" method="get">

            <div class="row">

                <div class="col-md-4">

                    <label class="form-label">
                        Search
                    </label>

                    <input type="text"
                           name="searchString"
                           value="@Context.Request.Query["searchString"]"
                           class="form-control"
                           placeholder="Employee No, Name or CNIC" />

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        Faculty
                    </label>

                    <select id="FacultyId"
                            name="facultyId"
                            class="form-select"
                            asp-items="ViewBag.FacultyId">

                        <option value="">All Faculties</option>

                    </select>

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        Department
                    </label>

                    <select id="DepartmentId"
                            name="departmentId"
                            class="form-select"
                            asp-items="ViewBag.DepartmentId">

                        <option value="">All Departments</option>

                    </select>

                </div>

            </div>

            <br />

            <div class="row">

                <div class="col-md-4">

                    <label class="form-label">
                        Designation
                    </label>

                    <select name="designationId"
                            class="form-select"
                            asp-items="ViewBag.DesignationId">

                        <option value="">All Designations</option>

                    </select>

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        Employment Type
                    </label>

                    <select name="employmentTypeId"
                            class="form-select"
                            asp-items="ViewBag.EmploymentTypeId">

                        <option value="">All Employment Types</option>

                    </select>

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        Status
                    </label>

                    <select name="isActive"
                            class="form-select">

                        <option value="">All</option>

                        <option value="true">Active</option>

                        <option value="false">Inactive</option>

                    </select>

                </div>

            </div>

            <br />

            <button type="submit"
                    class="btn btn-primary">

                Search

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Reset

            </a>

            <a asp-action="Create"
               class="btn btn-success float-end">

                Create Employee

            </a>

        </form>

    </div>

</div>

<table class="table table-bordered table-hover table-striped align-middle">

    <thead class="table-dark">

        <tr>
            <th width="90">Photo</th>

            <th>Employee No</th>

            <th>Name</th>

            <th>Department</th>

            <th>Designation</th>

            <th>Employment</th>

            <th>Mobile</th>

            <th>Status</th>

            <th width="220">Actions</th>

        </tr>

    </thead>

    <tbody>

        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">

                        @if (!string.IsNullOrEmpty(item.PhotoPath))
                        {
                            <img src="~/images/employees/@item.PhotoPath"
                                 class="rounded-circle"
                                 style="width:60px;height:60px;object-fit:cover;" />
                        }
                        else
                        {
                            <img src="~/images/no-image.png"
                                 class="rounded-circle"
                                 style="width:60px;height:60px;object-fit:cover;" />
                        }

                    </td>
                    <td>

                        <span class="badge bg-secondary">

                            @item.EmployeeNumber

                        </span>

                    </td>

                    <td>

                        <strong>@item.FullName</strong>

                    </td>

                    <td>

                        @item.Department?.DepartmentName

                    </td>

                    <td>

                        @item.Designation?.DesignationName

                    </td>

                    <td>

                        @item.EmploymentType?.EmploymentTypeName

                    </td>

                    <td>

                        @item.MobileNumber

                    </td>

                    <td>

                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">

                                Active

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">

                                Inactive

                            </span>
                        }

                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.EmployeeId"
                           class="btn btn-warning btn-sm">

                            Edit

                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.EmployeeId"
                           class="btn btn-info btn-sm text-white">

                            Details

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.EmployeeId"
                           class="btn btn-danger btn-sm">

                            Delete

                        </a>

                    </td>

                </tr>
            }
        }
        else
        {
            <tr>

                <td colspan="9"
                    class="text-center text-muted">

                    No employees found.

                </td>

            </tr>
        }

    </tbody>

</table>
@section Scripts
{
    <script>

        document.getElementById("FacultyId")
            .addEventListener("change", async function () {

                let facultyId = this.value;

                let department =
                    document.getElementById("DepartmentId");

                department.innerHTML =
                    '<option value="">All Departments</option>';

                if (facultyId === "")
                    return;

                const response =
                    await fetch(`/Employees/GetDepartments?facultyId=${facultyId}`);

                const data =
                    await response.json();

                data.forEach(function (item) {

                    let option =
                        document.createElement("option");

                    option.value = item.departmentId;

                    option.text = item.departmentName;

                    department.appendChild(option);

                });

            });

    </script>
}