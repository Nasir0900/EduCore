@model EduCore.Models.AcademicSession

@{
    ViewData["Title"] = "Edit Academic Session";
}

<h2>Edit Academic Session</h2>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="AcademicSessionId" />

            <div class="mb-3">
                <label asp-for="AcademicProgramId" class="form-label"></label>

                <select asp-for="AcademicProgramId"
                        class="form-select"
                        asp-items="ViewBag.AcademicProgramId">
                </select>

                <span asp-validation-for="AcademicProgramId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartYear" class="form-label"></label>

                <select asp-for="StartYear" class="form-select">

                    @{
                        int currentYear = DateTime.Now.Year;

                        for (int year = currentYear - 5; year <= currentYear + 10; year++)
                        {
                            if (year == Model.StartYear)
                            {
                                <option value="@year" selected>@year</option>
                            }
                            else
                            {
                                <option value="@year">@year</option>
                            }
                        }
                    }

                </select>

                <span asp-validation-for="StartYear" class="text-danger"></span>
            </div>

            <div class="form-check mb-2">
                <input asp-for="IsAdmissionOpen" class="form-check-input" />
                <label asp-for="IsAdmissionOpen" class="form-check-label"></label>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">
                Save Changes
            </button>

            <a asp-action="Details"
               asp-route-id="@Model.AcademicSessionId"
               class="btn btn-info text-white">
                Back to Details
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back to List
            </a>

        </form>

    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}